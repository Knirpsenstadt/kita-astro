# Required: simple password login for inline CMS
CMS_ADMIN_PASSWORD=change-me

# Optional: separate secret used for signed sessions
CMS_SESSION_SECRET=replace-with-long-random-string

# Optional: GitHub storage mode (recommended for deployed serverless runtime)
# If not set, CMS stores draft/published content in local file mode.
CMS_GITHUB_TOKEN=ghp_xxx
CMS_GITHUB_REPO=owner/repo
CMS_GITHUB_BRANCH=main
CMS_GITHUB_FILE_PATH=cms/inline-cms.json

# Optional local mode path
CMS_LOCAL_STORE_PATH=cms-data/inline-cms.json

---
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Elternverein Knirpsenstadt e.V.' } = Astro.props;

const pages = await getCollection('pages');
const sortedPages = pages
  .filter(p => p.data.menuOrder !== -1)
  .sort((a, b) => (a.data.menuOrder || 999) - (b.data.menuOrder || 999));

const navItems = [
  ...sortedPages.map((page) => ({
    href: page.data.permalink || `/${page.id}`,
    label: page.data.title,
    badge: false,
  })),
  { href: '/sponsoren/', label: 'Sponsoren/Spender', badge: false },
];
---

<!doctype html>
<html lang="de" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <title>{title} | Kita Knirpsenstadt</title>
  </head>
  <body class="min-h-screen pb-20">
    <header class="navbar bg-[#DAEFB4] shadow-sm sticky top-0 z-50 px-4 lg:px-6">
      <div class="navbar-start">
        <a href="/" class="btn btn-ghost text-xl normal-case gap-2">
          <img src="/img/logo.jpg" alt="Kita Knirpsenstadt" class="h-12 w-12 rounded-full" />
          <span class="hidden sm:inline text-lg font-bold">Kita Knirpsenstadt e.V.</span>
        </a>
      </div>
      
      <div class="navbar-center hidden xl:flex">
        <ul class="menu menu-horizontal px-1 text-base gap-0">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="px-3 xl:px-4">
                {item.label}
                {item.badge && <sup> 🔴</sup>}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <div class="navbar-end">
        <div class="dropdown dropdown-end">
          <label tabindex="0" class="btn btn-ghost xl:hidden">
            <i class="fas fa-bars text-xl"></i>
          </label>
          <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-56 right-0">
            <li><a href="/">Startseite</a></li>
            {navItems.map((item) => (
              <li>
                <a href={item.href}>
                  {item.label}
                  {item.badge && <sup> 🔴</sup>}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </header>

    <main class="container mx-auto px-4 lg:px-6 py-8 max-w-6xl">
      <slot />
    </main>

    <footer class="fixed bottom-0 left-0 right-0 bg-[#DAEFB4] py-4 text-center z-40">
      <p class="text-base mb-0">Elternverein Knirpsenstadt e.V.</p>
      <a href="/impressum" class="hover:underline font-medium text-base">Kontakt &amp; Impressum</a>
    </footer>
  </body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap');
  
  :root {
    --brand-50: #f5fbe9;
    --brand-100: #eaf6d3;
    --brand-400: #c9ebb2;
    --brand-600: #86c06a;
    --ink-700: #1f2937;
    --muted: #4b5563;
    --border: #e7eff7;
    --shadow: 0 8px 24px rgba(16,24,40,.08), 0 2px 6px rgba(16,24,40,.04);
  }
  
  html {
    font-family: 'Nunito', sans-serif;
    font-size: 17px;
  }
  
  body {
    background: linear-gradient(180deg, #ffffff 0%, #fbfdff 60%, #f6fbff 100%);
    line-height: 1.7;
  }
  
  .btn {
    text-transform: none;
    font-size: 1rem;
  }
  
  h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
  }
  
  h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  
  h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  
  p {
    margin-bottom: 1rem;
  }
  
  a {
    color: #5d9847;
  }
  
  a:hover {
    color: #4a7a3a;
  }
</style>

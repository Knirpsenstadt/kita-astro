---
import BaseLayout from '../layouts/BaseLayout.astro';
import Calendar from '../components/Calendar.astro';
import Carousel from '../components/Carousel.astro';
import { getBaselineEvents } from '../lib/cms/events';
import { getCmsRuntime } from '../lib/cms/runtime';

interface Props {
  title: string;
}

const { title } = Astro.props;
const cms = await getCmsRuntime(Astro);

const carouselImages = cms.carouselImages([]);
const eventsData = cms.events(getBaselineEvents());

const highlights = [
  {
    href: '/paedagogischer-ansatz/',
    icon: 'M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5',
    titleKey: 'home.highlights.0.title',
    title: 'Situationsansatz',
    textKey: 'home.highlights.0.text',
    text: 'Lernen in echten Situationen - flexibel nach den Beduerfnissen der Kinder'
  },
  {
    href: '/paedagogischer-ansatz/',
    icon: 'M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75-1.5.75a3.354 3.354 0 0 1-3 0 3.354 3.354 0 0 0-3 0 3.354 3.354 0 0 1-3 0 3.354 3.354 0 0 0-3 0 3.354 3.354 0 0 1-3 0L3 16.5m18-4.5a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
    titleKey: 'home.highlights.1.title',
    title: 'Frische Bio-Kueche',
    textKey: 'home.highlights.1.text',
    text: 'Täglich frisch gekocht - mit saisonalen Bioprodukten'
  },
  {
    href: '/team/',
    icon: 'M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z',
    titleKey: 'home.highlights.2.title',
    title: 'Vertraute Begleitung',
    textKey: 'home.highlights.2.text',
    text: 'Die gleiche Erzieherin begleitet Ihr Kind von 1 bis 6 Jahren'
  },
  {
    href: '/team/',
    icon: 'M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z',
    titleKey: 'home.highlights.3.title',
    title: 'Stabiles Team',
    textKey: 'home.highlights.3.text',
    text: 'Wenig Fluktuation - verlässliche Bezugspersonen ueber viele Jahre'
  },
  {
    href: '/vereinsleben/',
    icon: 'M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z',
    titleKey: 'home.highlights.4.title',
    title: 'Elterninitiative',
    textKey: 'home.highlights.4.text',
    text: 'Seit ueber 30 Jahren von Eltern gefuehrt - aktive Mitgestaltung erwuenscht'
  },
  {
    href: '/vereinsleben/',
    icon: 'M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5',
    titleKey: 'home.highlights.5.title',
    title: 'Viele Feste',
    textKey: 'home.highlights.5.text',
    text: 'Knirpsenfest, Lichterfest, Oma-Opa-Fest und mehr - bei uns wird gefeiert!'
  }
];

const quickFacts = [
  {
    icon: 'M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z',
    key: 'home.quickFacts.0',
    text: 'Direkt am S-Bhf Röntgental'
  },
  {
    icon: 'M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5',
    key: 'home.quickFacts.1',
    text: 'Nur 2 Wochen Sommerschliesszeit'
  },
  {
    icon: 'M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3',
    key: 'home.quickFacts.2',
    text: 'Eltern-App fuer Kommunikation'
  }
];

const openingHours = [
  { dayKey: 'home.hours.0.day', day: 'Mo', timeKey: 'home.hours.0.time', time: '6:30 - 16:30' },
  { dayKey: 'home.hours.1.day', day: 'Di', timeKey: 'home.hours.1.time', time: '6:30 - 16:30' },
  { dayKey: 'home.hours.2.day', day: 'Mi', timeKey: 'home.hours.2.time', time: '6:30 - 16:30' },
  { dayKey: 'home.hours.3.day', day: 'Do', timeKey: 'home.hours.3.time', time: '6:30 - 16:30' },
  { dayKey: 'home.hours.4.day', day: 'Fr', timeKey: 'home.hours.4.time', time: '6:30 - 16:00' },
  { dayKey: 'home.hours.5.day', day: 'Kernzeit', timeKey: 'home.hours.5.time', time: '9:00 - 11:30' },
];
---

<BaseLayout title={title} cms={cms}>
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-hero-copy">
      <p class="home-kicker">Elterninitiative in Zepernick</p>
      <h1 id="home-title">Kita Knirpsenstadt e.V.</h1>
      <p class="home-hero-text">Familiäre Betreuung, echtes Miteinander und viel Raum für Kinder von 1 bis 6 Jahren.</p>
    </div>

    <div class="open-places-banner">
      <div class="apply-row">
        <span class="text font-semibold" {...cms.attrs('home.banner.text')}>{cms.text('home.banner.text', 'Aufnahmen ab Sommer/Herbst 2026 - Interesse gerne schon jetzt melden.')}</span>
        <a class="btn-apply" href="mailto:leitung@knirpsenstadt.de?subject=Bewerbung%20Kita-Platz">
          <span {...cms.attrs('home.banner.button')}>{cms.text('home.banner.button', 'Jetzt bewerben')}</span>
        </a>
      </div>
      <a class="fee-note" href="/beitragsrechner/" aria-label="Beitrag online berechnen">
        <span class="fee-note-title" {...cms.attrs('home.fees.title')}>{cms.text('home.fees.title', 'Normale Kita-Gebühren')}</span>
        <span class="fee-note-text" {...cms.attrs('home.fees.text')}>{cms.text('home.fees.text', 'Beiträge nach Brandenburger Regelung.')}</span>
        <span class="fee-note-link" {...cms.attrs('home.fees.link')}>{cms.text('home.fees.link', 'Beitrag berechnen')}</span>
      </a>
    </div>
  </section>

  <div class="home-content-grid grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-10">
    <div class="home-main-column lg:col-span-2">
      <Carousel images={carouselImages} />
      <div id="startpage" class="mt-7">
        <div class="intro-card">
          <div class="intro-header">
            <div class="intro-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
            </div>
            <div>
              <h2 class="intro-title" {...cms.attrs('home.intro.title')}>{cms.text('home.intro.title', 'Willkommen in der Knirpsenstadt')}</h2>
              <p class="intro-subtitle" {...cms.attrs('home.intro.subtitle')}>{cms.text('home.intro.subtitle', 'Eine sanierte Privatvilla aus den 30er Jahren - seit 1992 unser Zuhause')}</p>
            </div>
          </div>

          <p class="intro-text" {...cms.attrs('home.intro.text')}>{cms.text('home.intro.text', '52 Kinder erleben in drei altersgemischten Gruppen einen harmonisch gestalteten Tagesablauf in familiärer Atmosphäre.')}</p>

          <div class="group-badges">
            <span class="group-badge snails">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582" /></svg>
              <span {...cms.attrs('home.groups.0')}>{cms.text('home.groups.0', 'Schnecken')}</span>
            </span>
            <span class="group-badge hedgehogs">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
              <span {...cms.attrs('home.groups.1')}>{cms.text('home.groups.1', 'Igel')}</span>
            </span>
            <span class="group-badge butterflies">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z" /></svg>
              <span {...cms.attrs('home.groups.2')}>{cms.text('home.groups.2', 'Schmetterlinge')}</span>
            </span>
          </div>
        </div>
      </div>

      <div class="mt-8">
        <h2 class="text-xl font-bold mb-5 text-[#4a7a3a]" {...cms.attrs('home.highlights.heading')}>{cms.text('home.highlights.heading', 'Was uns besonders macht')}</h2>
        <div class="highlights-grid">
          {highlights.map((item) => (
            <a href={item.href} class="highlight-card">
              <div class="highlight-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d={item.icon} /></svg>
              </div>
              <div class="highlight-content">
                <h3 {...cms.attrs(item.titleKey)}>{cms.text(item.titleKey, item.title)}</h3>
                <p {...cms.attrs(item.textKey)}>{cms.text(item.textKey, item.text)}</p>
              </div>
            </a>
          ))}
        </div>

        <div class="quick-facts mt-6">
          {quickFacts.map((fact) => (
            <div class="quick-fact">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d={fact.icon} /></svg>
              <span {...cms.attrs(fact.key)}>{cms.text(fact.key, fact.text)}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <aside class="lg:col-span-1">
      <div class="sticky top-24">
        <h2 class="text-xl font-bold mb-4" {...cms.attrs('home.hours.heading')}>{cms.text('home.hours.heading', 'Öffnungszeiten')}</h2>
        <div class="bg-white rounded-2xl shadow border border-gray-100 overflow-hidden">
          <table class="w-full">
            <tbody>
              {openingHours.map((row, index) => (
                <tr class={index < openingHours.length - 1 ? 'border-b border-gray-100 hover:bg-gray-50 transition-colors' : 'hover:bg-gray-50 transition-colors'}>
                  <td class="p-4 bg-[#f5fbe9] font-semibold text-[#4a7a3a] w-24" {...cms.attrs(row.dayKey)}>{cms.text(row.dayKey, row.day)}</td>
                  <td class="p-4 font-semibold" {...cms.attrs(row.timeKey)}>{cms.text(row.timeKey, row.time)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h3 class="text-xl font-bold mt-8 mb-4" {...cms.attrs('home.calendar.heading')}>{cms.text('home.calendar.heading', 'Kalender')}</h3>
        <Calendar events={eventsData} />
      </div>
    </aside>
  </div>
</BaseLayout>

<style>
  .home-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1.25rem;
    align-items: stretch;
    margin-bottom: 2.25rem;
  }

  .home-hero-copy {
    max-width: 780px;
  }

  .home-kicker {
    margin: 0 0 0.65rem;
    color: var(--brand-700);
    font-size: 0.92rem;
    font-weight: 800;
    letter-spacing: 0.075em;
    text-transform: uppercase;
  }

  .home-hero-copy h1 {
    margin-bottom: 0.85rem;
  }

  .home-hero-text {
    max-width: 58ch;
    margin: 0;
    color: var(--ink-600);
    font-size: 1.1rem;
    line-height: 1.65;
    text-wrap: pretty;
  }

  @media (min-width: 900px) {
    .home-hero {
      grid-template-columns: minmax(0, 1fr) minmax(320px, 390px);
      gap: 2.25rem;
      margin-bottom: 2.6rem;
    }
  }

  @media (min-width: 1024px) {
    .home-content-grid {
      align-items: start;
    }

    .home-main-column {
      margin-top: -8.5rem;
    }
  }

  .open-places-banner {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 16px;
    background:
      radial-gradient(circle at 92% 12%, rgba(255, 255, 255, 0.22), transparent 34%),
      linear-gradient(135deg, #86c06a 0%, #5d9847 100%);
    color: #fff;
    padding: 20px 24px;
    border-radius: 16px;
    box-shadow: 0 14px 34px rgba(93, 152, 71, 0.18), 0 2px 8px rgba(74, 122, 58, 0.1);
  }

  .apply-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .open-places-banner .text {
    font-size: 1.05rem;
    letter-spacing: 0.01em;
    line-height: 1.45;
    flex: 1 1 210px;
  }

  .open-places-banner .btn-apply {
    background: #fff;
    color: #1f2937;
    font-weight: 700;
    text-decoration: none;
    padding: 12px 28px;
    border-radius: 999px;
    box-shadow: 0 8px 18px rgba(45, 75, 36, 0.18);
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
    white-space: nowrap;
    font-size: 1rem;
  }

  .fee-note {
    display: grid;
    gap: 0.12rem;
    padding: 0.72rem 0.85rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.58);
    border-radius: 14px;
    color: var(--ink-700);
    text-decoration: none;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.82), 0 10px 22px rgba(45, 75, 36, 0.12);
    transition: transform 0.2s, background 0.2s, box-shadow 0.2s;
  }

  .fee-note:hover {
    transform: translateY(-2px);
    background: #fff;
    color: var(--ink-700);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9), 0 14px 28px rgba(45, 75, 36, 0.18);
  }

  .fee-note:active {
    transform: translateY(0);
  }

  .fee-note-title {
    color: var(--brand-800);
    font-size: 0.92rem;
    font-weight: 800;
    line-height: 1.25;
  }

  .fee-note-text {
    color: var(--ink-600);
    font-size: 0.8rem;
    line-height: 1.3;
  }

  .fee-note-link {
    width: fit-content;
    margin-top: 0.2rem;
    color: var(--brand-800);
    font-size: 0.8rem;
    font-weight: 800;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .open-places-banner .btn-apply:hover {
    transform: translateY(-2px);
    background: var(--brand-50);
    box-shadow: 0 12px 26px rgba(45, 75, 36, 0.24);
  }

  .open-places-banner .btn-apply:active {
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .open-places-banner {
      text-align: center;
      padding: 16px 20px;
    }
    .apply-row {
      flex-direction: column;
      text-align: center;
    }
    .open-places-banner .btn-apply {
      width: 100%;
      text-align: center;
    }
    .open-places-banner .text {
      flex: 0 1 auto;
    }
    .fee-note-link {
      margin-left: auto;
      margin-right: auto;
    }
  }

  .intro-card {
    background: linear-gradient(135deg, rgba(245, 251, 233, 0.96) 0%, rgba(255, 255, 255, 0.9) 100%);
    border: 1px solid rgba(168, 217, 138, 0.36);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: 0 12px 32px rgba(74, 122, 58, 0.07);
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.05rem;
  }

  @media (min-width: 640px) {
    .highlights-grid {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }
  }

  .highlight-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    min-width: 0;
    padding: 1.25rem;
    background: rgba(255, 255, 255, 0.86);
    border: 1px solid rgba(229, 231, 235, 0.82);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }

  .highlight-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 32px rgba(74, 122, 58, 0.08);
    border-color: var(--brand-200);
  }

  .highlight-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--brand-50);
    border-radius: var(--radius-sm);
    border: 1px solid var(--brand-100);
  }

  .highlight-icon svg {
    width: 26px;
    height: 26px;
    color: var(--brand-700);
  }

  .highlight-content h3 {
    margin: 0 0 0.35rem 0;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink-700);
    overflow-wrap: anywhere;
  }

  .highlight-content p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.45;
    overflow-wrap: anywhere;
  }

  .quick-facts {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--brand-50);
    border: 1px solid rgba(168, 217, 138, 0.34);
    border-radius: var(--radius-md);
  }

  .quick-fact {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--brand-800);
  }

  .quick-fact svg {
    width: 20px;
    height: 20px;
    color: var(--brand-600);
  }

  @media (max-width: 640px) {
    .quick-facts {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>

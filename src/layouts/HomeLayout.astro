---
import BaseLayout from '../layouts/BaseLayout.astro';
import Calendar from '../components/Calendar.astro';
import Carousel from '../components/Carousel.astro';

interface Props {
  title: string;
  body: string;
}

const { title, body } = Astro.props;
---

<BaseLayout title={title}>
  <div class="open-places-banner mb-6">
    <span class="text font-semibold">Aufnahmen ab Sommer/Herbst 2026 – Interesse gerne schon jetzt melden.</span>
    <a class="btn-apply" href="mailto:leitung@knirpsenstadt.de?subject=Bewerbung%20Kita-Platz">Jetzt bewerben</a>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-8 gap-6">
    <div class="lg:col-span-6">
      <Carousel />
      <div id="startpage" class="mt-4 p-4 rounded-xl bg-white shadow-sm">
        <div class="intro-card bg-[#f5fbe9] border border-[#eaf6d3] rounded-xl p-4 mb-4 shadow-sm">
          <Fragment set:html={body} />
        </div>
      </div>
    </div>

    <aside class="lg:col-span-2">
      <div class="sticky top-20">
        <h2 class="text-lg font-bold mb-3">Öffnungszeiten</h2>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
          <table class="w-full text-sm">
            <tbody>
              <tr class="border-b border-gray-100">
                <td class="p-3 bg-[#f5fbe9] font-semibold">Mo</td>
                <td class="p-3 font-semibold">6:30 – 16:30</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="p-3 bg-[#f5fbe9] font-semibold">Di</td>
                <td class="p-3 font-semibold">6:30 – 16:30</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="p-3 bg-[#f5fbe9] font-semibold">Mi</td>
                <td class="p-3 font-semibold">6:30 – 16:30</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="p-3 bg-[#f5fbe9] font-semibold">Do</td>
                <td class="p-3 font-semibold">6:30 – 16:30</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="p-3 bg-[#f5fbe9] font-semibold">Fr</td>
                <td class="p-3 font-semibold">6:30 – 16:00</td>
              </tr>
              <tr>
                <td class="p-3 bg-[#f5fbe9] font-semibold">Kernzeit</td>
                <td class="p-3 font-semibold">9:00 – 11:30</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3 class="text-lg font-bold mt-6 mb-3">Kalender</h3>
        <Calendar />
      </div>
    </aside>
  </div>
</BaseLayout>

<style>
  .open-places-banner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    background: linear-gradient(90deg, #86c06a 0%, #5d9847 100%);
    color: #fff;
    padding: 14px 22px;
    border-radius: 16px;
    box-shadow: var(--shadow);
  }

  .open-places-banner .text {
    font-size: 1.15rem;
    letter-spacing: 0.3px;
  }

  .open-places-banner .btn-apply {
    background: #fff;
    color: #1f2937;
    font-weight: 700;
    text-decoration: none;
    padding: 10px 24px;
    border-radius: 999px;
    box-shadow: 0 2px 4px rgba(0,0,0,.15);
    transition: transform 0.2s, box-shadow 0.2s;
    white-space: nowrap;
  }

  .open-places-banner .btn-apply:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(0,0,0,.25);
  }

  @media (max-width: 768px) {
    .open-places-banner {
      flex-direction: column;
      text-align: center;
    }
    .open-places-banner .btn-apply {
      width: 100%;
      text-align: center;
    }
  }
</style>

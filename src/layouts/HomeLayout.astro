---
import BaseLayout from '../layouts/BaseLayout.astro';
import Calendar from '../components/Calendar.astro';
import Carousel from '../components/Carousel.astro';
import { getCollection } from 'astro:content';
import { toYMD } from '../utils/date';

interface Props {
  title: string;
  body: string;
}

const { title, body } = Astro.props;

const events = await getCollection('events');
const eventsData = events.map(e => ({
  label: e.data.label,
  type: e.data.type,
  start: toYMD(e.data.start),
  end: toYMD(e.data.end || e.data.start)
}));
---

<BaseLayout title={title}>
  <div class="open-places-banner mb-8">
    <span class="text font-semibold">Aufnahmen ab Sommer/Herbst 2026 – Interesse gerne schon jetzt melden.</span>
    <a class="btn-apply" href="mailto:leitung@knirpsenstadt.de?subject=Bewerbung%20Kita-Platz">Jetzt bewerben</a>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2">
      <Carousel />
      <div id="startpage" class="mt-6 p-6 rounded-xl bg-white shadow-sm border border-gray-100">
        <div class="intro-card bg-[#f5fbe9] border border-[#eaf6d3] rounded-xl p-6 shadow-sm">
          <Fragment set:html={body} />
        </div>
      </div>
    </div>

    <aside class="lg:col-span-1">
      <div class="sticky top-24">
        <h2 class="text-xl font-bold mb-4">Öffnungszeiten</h2>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
          <table class="w-full">
            <tbody>
              <tr class="border-b border-gray-100">
                <td class="p-4 bg-[#f5fbe9] font-semibold">Mo</td>
                <td class="p-4 font-semibold">6:30 – 16:30</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="p-4 bg-[#f5fbe9] font-semibold">Di</td>
                <td class="p-4 font-semibold">6:30 – 16:30</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="p-4 bg-[#f5fbe9] font-semibold">Mi</td>
                <td class="p-4 font-semibold">6:30 – 16:30</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="p-4 bg-[#f5fbe9] font-semibold">Do</td>
                <td class="p-4 font-semibold">6:30 – 16:30</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="p-4 bg-[#f5fbe9] font-semibold">Fr</td>
                <td class="p-4 font-semibold">6:30 – 16:00</td>
              </tr>
              <tr>
                <td class="p-4 bg-[#f5fbe9] font-semibold">Kernzeit</td>
                <td class="p-4 font-semibold">9:00 – 11:30</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3 class="text-xl font-bold mt-8 mb-4">Kalender</h3>
        <Calendar events={eventsData} />
      </div>
    </aside>
  </div>
</BaseLayout>

<style>
  .open-places-banner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    background: linear-gradient(90deg, #86c06a 0%, #5d9847 100%);
    color: #fff;
    padding: 18px 28px;
    border-radius: 16px;
    box-shadow: var(--shadow);
  }

  .open-places-banner .text {
    font-size: 1.2rem;
    letter-spacing: 0.3px;
  }

  .open-places-banner .btn-apply {
    background: #fff;
    color: #1f2937;
    font-weight: 700;
    text-decoration: none;
    padding: 12px 28px;
    border-radius: 999px;
    box-shadow: 0 2px 4px rgba(0,0,0,.15);
    transition: transform 0.2s, box-shadow 0.2s;
    white-space: nowrap;
    font-size: 1rem;
  }

  .open-places-banner .btn-apply:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(0,0,0,.25);
  }

  @media (max-width: 768px) {
    .open-places-banner {
      flex-direction: column;
      text-align: center;
      padding: 16px 20px;
    }
    .open-places-banner .btn-apply {
      width: 100%;
      text-align: center;
    }
  }
</style>

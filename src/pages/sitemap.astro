---
import BaseLayout from '../layouts/BaseLayout.astro';

const pages = [
  { title: 'Pädagogischer Ansatz', permalink: '/paedagogischer-ansatz' },
  { title: 'Team', permalink: '/team' },
  { title: 'Kalender', permalink: '/kalender' },
  { title: 'Vereinsleben', permalink: '/vereinsleben' },
  { title: 'Sponsoren', permalink: '/sponsoren' },
  { title: 'Dokumente', permalink: '/dokumente' },
  { title: 'Offene Stellen', permalink: '/offene-stellen' },
];
---

<BaseLayout title="Sitemap">
  <h1 class="text-2xl font-bold mb-6">Seitenübersicht</h1>
  <ul class="menu bg-base-100 rounded-box shadow-sm border border-gray-100 p-4">
    <li><a href="/" class="hover:bg-[#f5fbe9]">Startseite</a></li>
    {pages.map(page => (
      <li><a href={page.permalink} class="hover:bg-[#f5fbe9]">{page.title}</a></li>
    ))}
    <li><a href="/beitragsrechner" class="hover:bg-[#f5fbe9] font-semibold">Beitragsrechner</a></li>
    <li><a href="/impressum" class="hover:bg-[#f5fbe9]">Impressum</a></li>
  </ul>
</BaseLayout>
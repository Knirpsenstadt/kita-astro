---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getSession, setModeCookie } from '../../lib/cms/auth'
import '../../styles/global.css'

const session = getSession(Astro.cookies)

if (!session) {
  return Astro.redirect('/admin?next=/admin/calendar')
}

setModeCookie(Astro.cookies, Astro.request, 'draft')

const csrfToken = session.csrf
---

<BaseLayout title="Admin - Kalender" description="Kalenderverwaltung">
  <article class="admin-shell">
    <div class="admin-head">
      <h1>Kalender Einträge</h1>
      <div class="admin-actions">
        <a class="admin-btn subtle" href="/admin">Zurück</a>
        <button type="button" id="load-live-btn" class="admin-btn subtle">Live-Daten laden</button>
        <button type="button" id="load-baseline-btn" class="admin-btn subtle">Website-Standard laden</button>
        <button type="button" id="save-events-btn" class="admin-btn">Entwurf speichern</button>
        <button type="button" id="publish-btn" class="admin-btn">Publizieren</button>
      </div>
    </div>

    <p class="admin-intro">Sortierung automatisch nach Typ und Datum. Elterntermine, Familienveranstaltungen, Kinderaktionen und Schließzeiten getrennt pflegen.</p>
    <p id="source-hint" class="source-hint"></p>
    <p id="admin-status" class="admin-state" aria-live="polite"></p>

    <div class="table-toolbar">
      <div class="toolbar-filters">
        <div class="type-filter" role="group" aria-label="Typ Filter">
          <button type="button" class="filter-chip" data-type-filter="all">Alle</button>
          <button type="button" class="filter-chip" data-type-filter="parent">Elterntermin</button>
          <button type="button" class="filter-chip" data-type-filter="family">Familienveranstaltung</button>
          <button type="button" class="filter-chip" data-type-filter="child">Kinderaktion</button>
          <button type="button" class="filter-chip" data-type-filter="closure">Schließzeit</button>
        </div>

        <button type="button" id="clear-filters-btn" class="admin-btn subtle small">Filter zurücksetzen</button>
        <span id="filter-hint" class="filter-hint"></span>
      </div>

      <button type="button" id="add-event-btn" class="admin-btn">Termin hinzufügen</button>
    </div>

    <div class="admin-calendar-layout">
      <section class="admin-calendar-panel">
        <div class="calendar-board-head">
          <div>
            <h2 id="calendar-range-label" class="calendar-board-title">Kalender</h2>
            <p id="calendar-mode-note" class="calendar-board-note" hidden>Erstellmodus: Der erste Klick setzt den Start, der zweite Klick das Ende.</p>
          </div>
          <div class="calendar-nav">
            <button type="button" id="calendar-prev-btn" class="admin-btn subtle small" aria-label="Vorherige Monate">‹</button>
            <button type="button" id="calendar-today-btn" class="admin-btn subtle small">Heute</button>
            <button type="button" id="calendar-next-btn" class="admin-btn subtle small" aria-label="Nächste Monate">›</button>
          </div>
        </div>

        <div id="events-list" class="admin-month-grid"></div>

      </section>

      <aside id="calendar-inspector" class="calendar-inspector"></aside>
    </div>
  </article>
</BaseLayout>

<script is:inline data-astro-rerun define:vars={{ csrfToken }}>
  const TYPE_ORDER = {
    parent: 0,
    family: 1,
    child: 2,
    closure: 3,
  };

  const TYPE_OPTIONS = [
    { value: 'parent', label: 'Elterntermin' },
    { value: 'family', label: 'Familienveranstaltung' },
    { value: 'child', label: 'Kinderaktion' },
    { value: 'closure', label: 'Schließzeit' },
  ];

  const TYPE_META = {
    parent: { label: 'Elterntermin', className: 'type-parent' },
    family: { label: 'Familienveranstaltung', className: 'type-family' },
    child: { label: 'Kinderaktion', className: 'type-child' },
    closure: { label: 'Schließzeit', className: 'type-closure' },
  };

  const MONTH_NAMES = ['Januar', 'Februar', 'März', 'April', 'Mai', 'Juni', 'Juli', 'August', 'September', 'Oktober', 'November', 'Dezember'];
  const WEEKDAY_NAMES = ['Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa', 'So'];
  const MONTHS_PER_PAGE = 3;

  const state = {
    events: [],
    publishedEvents: [],
    baselineEvents: [],
    source: 'draft',
    filterType: 'all',
    viewYear: new Date().getFullYear(),
    viewMonth: new Date().getMonth(),
    selectedDate: todayYmd(),
    selectedEntryId: '',
    createDraft: null,
    draftStep: 'pick_start',
  };

  function createId(prefix) {
    return `${prefix}-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
  }

  function todayYmd() {
    const now = new Date();
    return formatDateToYmd(now);
  }

  function formatDateToYmd(value) {
    const y = value.getFullYear();
    const m = String(value.getMonth() + 1).padStart(2, '0');
    const d = String(value.getDate()).padStart(2, '0');
    return `${y}-${m}-${d}`;
  }

  function parseYmd(value) {
    if (typeof value !== 'string') return null;
    const match = value.trim().match(/^(\d{4})-(\d{2})-(\d{2})$/);
    if (!match) return null;
    return new Date(Number(match[1]), Number(match[2]) - 1, Number(match[3]));
  }

  function formatLongDate(value) {
    const date = parseYmd(value);
    if (!date) return 'Kein Datum';
    return date.toLocaleDateString('de-DE', { weekday: 'long', day: '2-digit', month: '2-digit', year: 'numeric' });
  }

  function formatShortDate(value) {
    const date = parseYmd(value);
    if (!date) return 'TT.MM.JJJJ';
    return date.toLocaleDateString('de-DE');
  }

  function formatDateRange(start, end) {
    if (!start) return 'Noch kein Datum gesetzt';
    if (!end || end === start) return formatShortDate(start);
    return `${formatShortDate(start)} - ${formatShortDate(end)}`;
  }

  function addMonths(year, month, delta) {
    const date = new Date(year, month + delta, 1);
    return { year: date.getFullYear(), month: date.getMonth() };
  }

  function compareYmd(a, b) {
    return String(a || '').localeCompare(String(b || ''));
  }

  function buildDraft(defaultDate = '') {
    const presetType = state.filterType !== 'all' ? state.filterType : 'parent';
    return {
      id: createId('entry'),
      label: '',
      type: presetType,
      start: defaultDate,
      end: '',
    };
  }

  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function setStatus(text, isError) {
    const node = document.getElementById('admin-status');
    if (!node) return;
    node.textContent = text;
    node.classList.toggle('error', !!isError);
  }

  function setSourceHint() {
    const node = document.getElementById('source-hint');
    if (!node) return;
    const label = state.source === 'baseline' ? 'Website-Standard' : state.source === 'published' ? 'Live' : 'Entwurf';
    node.textContent = `Aktuelle Quelle: ${label} (${state.events.length} Einträge)`;
  }

  function setFilterHint(visibleCount) {
    const node = document.getElementById('filter-hint');
    if (!node) return;
    const filtered = state.filterType !== 'all';
    node.textContent = filtered
      ? `${visibleCount} von ${state.events.length} Einträgen sichtbar`
      : `${state.events.length} Einträge`;
  }

  function markDraftSource() {
    state.source = 'draft';
    setSourceHint();
  }

  function syncTypeFilterButtons() {
    document.querySelectorAll('[data-type-filter]').forEach((button) => {
      const isActive = button.dataset.typeFilter === state.filterType;
      button.classList.toggle('active', isActive);
    });
  }

  function compareEvents(a, b) {
    const aType = TYPE_ORDER[a.type] ?? 99;
    const bType = TYPE_ORDER[b.type] ?? 99;
    if (aType !== bType) {
      return aType - bType;
    }

    const aStart = typeof a.start === 'string' ? a.start : '';
    const bStart = typeof b.start === 'string' ? b.start : '';
    if (aStart !== bStart) {
      return aStart.localeCompare(bStart);
    }

    const aEnd = typeof a.end === 'string' && a.end ? a.end : aStart;
    const bEnd = typeof b.end === 'string' && b.end ? b.end : bStart;
    if (aEnd !== bEnd) {
      return aEnd.localeCompare(bEnd);
    }

    return 0;
  }

  function sortEvents(items) {
    return [...items].sort(compareEvents);
  }

  function matchesFilters(entry) {
    if (state.filterType !== 'all' && entry.type !== state.filterType) {
      return false;
    }

    return true;
  }

  function getVisibleEntries() {
    return state.events
      .map((entry, index) => ({ entry, index }))
      .sort((a, b) => compareEvents(a.entry, b.entry))
      .filter((item) => matchesFilters(item.entry));
  }

  async function api(url, options) {
    const response = await fetch(url, options);
    const result = await response.json().catch(() => ({ error: 'Unerwartete Antwort.' }));
    if (!response.ok) {
      throw new Error(result.error || 'Anfrage fehlgeschlagen.');
    }
    return result;
  }

  function renderTypeOptions(selectedType) {
    return TYPE_OPTIONS.map((option) => {
      const selected = option.value === selectedType ? ' selected' : '';
      return `<option value="${option.value}"${selected}>${escapeHtml(option.label)}</option>`;
    }).join('');
  }

  function renderTypeChips(selectedType, mode, entryId = '') {
    return (
      `<div class="type-chip-group" role="group" aria-label="Typ auswählen">` +
        TYPE_OPTIONS.map((option) => {
          const meta = TYPE_META[option.value] || TYPE_META.parent;
          const active = option.value === selectedType ? ' active' : '';
          const target = mode === 'draft'
            ? `data-draft-type="${option.value}"`
            : `data-entry-type="${option.value}" data-entry-id="${escapeHtml(entryId)}"`;
          return `<button type="button" class="type-chip ${meta.className}${active}" ${target}>${escapeHtml(option.label)}</button>`;
        }).join('') +
      `</div>`
    );
  }

  function getEntryById(id) {
    return state.events.find((entry) => entry.id === id) || null;
  }

  function getEntryIndexById(id) {
    return state.events.findIndex((entry) => entry.id === id);
  }

  function normalizeEntryRange(entry) {
    if (entry.start && entry.end && compareYmd(entry.end, entry.start) < 0) {
      const nextStart = entry.end;
      entry.end = entry.start;
      entry.start = nextStart;
    }
  }

  function updateEntryField(id, field, value) {
    const entry = getEntryById(id);
    if (!entry) return;
    entry[field] = value;
    normalizeEntryRange(entry);
    markDraftSource();
    renderEvents();
  }

  function removeEntry(id) {
    const index = getEntryIndexById(id);
    if (index === -1) return;
    const label = (state.events[index].label || 'diesen Eintrag').trim();
    if (!window.confirm(`Eintrag "${label}" wirklich löschen?`)) return;
    state.events.splice(index, 1);
    if (state.selectedEntryId === id) {
      state.selectedEntryId = '';
    }
    markDraftSource();
    renderEvents();
  }

  function getEntriesForDay(ymd) {
    return getVisibleEntries().filter(({ entry }) => {
      const start = entry.start || '';
      const end = entry.end || entry.start || '';
      return !!start && compareYmd(ymd, start) >= 0 && compareYmd(ymd, end) <= 0;
    });
  }

  function getMarkerTypes(items) {
    return Array.from(new Set(items.map(({ entry }) => entry.type)))
      .sort((a, b) => (TYPE_ORDER[a] ?? 99) - (TYPE_ORDER[b] ?? 99))
      .slice(0, 3);
  }

  function getDominantType(items) {
    const marker = getMarkerTypes(items)[0];
    return marker ? `type-${marker}` : '';
  }

  function isDraftDay(ymd) {
    if (!state.createDraft?.start) return false;
    const draftStart = state.createDraft.start;
    const draftEnd = state.createDraft.end || draftStart;
    return compareYmd(ymd, draftStart) >= 0 && compareYmd(ymd, draftEnd) <= 0;
  }

  function ensureUiState(visibleEntries) {
    const visibleIds = new Set(visibleEntries.map(({ entry }) => entry.id));
    if (state.selectedEntryId && !visibleIds.has(state.selectedEntryId)) {
      state.selectedEntryId = '';
    }
    if (!state.selectedDate) {
      state.selectedDate = todayYmd();
    }
  }

  function getRangeLabel() {
    const start = new Date(state.viewYear, state.viewMonth, 1);
    const end = new Date(state.viewYear, state.viewMonth + MONTHS_PER_PAGE - 1, 1);
    const startLabel = `${MONTH_NAMES[start.getMonth()]} ${start.getFullYear()}`;
    const endLabel = `${MONTH_NAMES[end.getMonth()]} ${end.getFullYear()}`;
    return startLabel === endLabel ? startLabel : `${startLabel} - ${endLabel}`;
  }

  function monthGridDates(year, month) {
    const first = new Date(year, month, 1);
    const leadingEmpty = (first.getDay() + 6) % 7;
    const totalDays = new Date(year, month + 1, 0).getDate();
    const cells = Array.from({ length: leadingEmpty }, () => null);
    for (let day = 1; day <= totalDays; day += 1) {
      cells.push(new Date(year, month, day));
    }
    return cells;
  }

  function renderMonthCard(year, month) {
    const dates = monthGridDates(year, month);
    const label = `${MONTH_NAMES[month]} ${year}`;
    const cells = dates.map((date) => {
      if (!date) {
        return '<span class="admin-day-spacer" aria-hidden="true"></span>';
      }
      const ymd = formatDateToYmd(date);
      const items = getEntriesForDay(ymd);
      const weekend = date.getDay() === 0 || date.getDay() === 6 ? ' is-weekend' : '';
      const selected = state.selectedDate === ymd ? ' is-selected' : '';
      const draft = isDraftDay(ymd) ? ' is-draft' : '';
      const dominantType = items.length ? ` ${getDominantType(items)}` : '';
      const markers = getMarkerTypes(items)
        .map((type) => `<span class="day-marker ${type}"></span>`)
        .join('');
      const count = items.length > 1 ? `<span class="day-count">${items.length}</span>` : '';
      return (
        `<button type="button" class="admin-day${weekend}${selected}${draft}${dominantType}" data-day="${ymd}">` +
          `<span class="day-number">${date.getDate()}</span>` +
          `${count}` +
          `<span class="day-markers">${markers}</span>` +
        `</button>`
      );
    }).join('');

    return (
      `<section class="admin-month-card">` +
        `<div class="admin-month-title">${label}</div>` +
        `<div class="admin-weekdays">${WEEKDAY_NAMES.map((name) => `<span>${name}</span>`).join('')}</div>` +
        `<div class="admin-days">${cells}</div>` +
      `</section>`
    );
  }

  function bindCalendarEvents() {
    document.querySelectorAll('[data-day]').forEach((button) => {
      button.addEventListener('click', () => handleDayClick(button.dataset.day || ''));
    });
  }

  function renderCalendar() {
    const list = document.getElementById('events-list');
    const rangeLabel = document.getElementById('calendar-range-label');
    if (!list) return;

    rangeLabel.textContent = getRangeLabel();
    list.innerHTML = Array.from({ length: MONTHS_PER_PAGE }, (_, index) => {
      const next = addMonths(state.viewYear, state.viewMonth, index);
      return renderMonthCard(next.year, next.month);
    }).join('');
    bindCalendarEvents();
  }

  function bindInspectorEvents() {
    const inspector = document.getElementById('calendar-inspector');
    if (!inspector) return;

    inspector.querySelectorAll('[data-entry-select]').forEach((button) => {
      button.addEventListener('click', () => {
        state.selectedEntryId = button.dataset.entrySelect || '';
        state.createDraft = null;
        renderEvents();
      });
    });

    inspector.querySelector('[data-action="cancel-create"]')?.addEventListener('click', () => {
      state.createDraft = null;
      state.draftStep = 'pick_start';
      renderEvents();
    });

    inspector.querySelector('[data-action="save-create"]')?.addEventListener('click', () => {
      const draft = state.createDraft;
      if (!draft) return;
      const label = draft.label.trim();
      if (!label || !draft.start) {
        setStatus('Neuer Eintrag braucht mindestens Bezeichnung und Startdatum.', true);
        return;
      }
      const createdEntry = {
        id: draft.id,
        label,
        type: draft.type || 'parent',
        start: draft.start,
        end: draft.end || '',
      };
      normalizeEntryRange(createdEntry);
      state.events.push(createdEntry);
      state.events = sortEvents(state.events);
      state.selectedEntryId = createdEntry.id;
      state.selectedDate = createdEntry.start;
      state.createDraft = null;
      state.draftStep = 'pick_start';
      markDraftSource();
      setStatus('Neuer Eintrag angelegt.');
      renderEvents();
    });

    inspector.querySelector('[data-action="clear-draft-range"]')?.addEventListener('click', () => {
      if (!state.createDraft) return;
      state.createDraft.start = '';
      state.createDraft.end = '';
      state.draftStep = 'pick_start';
      renderEvents();
    });

    inspector.querySelectorAll('[data-draft-field]').forEach((field) => {
      field.addEventListener('input', (event) => {
        if (!state.createDraft) return;
        const key = event.currentTarget.dataset.draftField;
        state.createDraft[key] = event.currentTarget.value;
      });
      field.addEventListener('change', (event) => {
        if (!state.createDraft) return;
        const key = event.currentTarget.dataset.draftField;
        state.createDraft[key] = event.currentTarget.value;
        normalizeEntryRange(state.createDraft);
        renderEvents();
      });
    });

    inspector.querySelectorAll('[data-draft-type]').forEach((button) => {
      button.addEventListener('click', () => {
        if (!state.createDraft) return;
        state.createDraft.type = button.dataset.draftType || 'parent';
        renderEvents();
      });
    });

    inspector.querySelectorAll('[data-entry-field]').forEach((field) => {
      field.addEventListener('input', (event) => {
        const id = event.currentTarget.dataset.entryId || '';
        const key = event.currentTarget.dataset.entryField;
        if (!id || !key) return;
        const entry = getEntryById(id);
        if (!entry) return;
        entry[key] = event.currentTarget.value;
        markDraftSource();
      });
      field.addEventListener('change', (event) => {
        const id = event.currentTarget.dataset.entryId || '';
        const key = event.currentTarget.dataset.entryField;
        if (!id || !key) return;
        updateEntryField(id, key, event.currentTarget.value);
      });
    });

    inspector.querySelectorAll('[data-entry-type]').forEach((button) => {
      button.addEventListener('click', () => {
        const id = button.dataset.entryId || '';
        const type = button.dataset.entryType || 'parent';
        if (!id) return;
        updateEntryField(id, 'type', type);
      });
    });

    inspector.querySelector('[data-action="clear-selection"]')?.addEventListener('click', () => {
      state.selectedEntryId = '';
      renderEvents();
    });

    inspector.querySelector('[data-action="remove-entry"]')?.addEventListener('click', () => {
      const id = inspector.querySelector('[data-action="remove-entry"]').dataset.entryId || '';
      if (id) {
        removeEntry(id);
      }
    });
  }

  function renderDayInspector() {
    const inspector = document.getElementById('calendar-inspector');
    if (!inspector) return;
    const selectedDate = state.selectedDate || todayYmd();
    const items = getEntriesForDay(selectedDate);
    const content = items.length
      ? (
        `<div class="inspector-stack">` +
          items.map(({ entry }) => {
            const meta = TYPE_META[entry.type] || TYPE_META.parent;
            return (
              `<button type="button" class="day-entry-link ${meta.className}" data-entry-select="${escapeHtml(entry.id)}">` +
                `<span class="entry-link-title">${escapeHtml(entry.label || 'Ohne Titel')}</span>` +
                `<span class="entry-link-meta">${escapeHtml(meta.label)} · ${escapeHtml(formatDateRange(entry.start, entry.end || ''))}</span>` +
              `</button>`
            );
          }).join('') +
        `</div>`
      )
      : '<p class="inspector-empty">Keine sichtbaren Einträge an diesem Tag.</p>';

    inspector.innerHTML =
      `<div class="inspector-card">` +
        `<div class="inspector-head">` +
          `<div>` +
            `<p class="inspector-kicker">Tagesdetails</p>` +
            `<h3>${escapeHtml(formatLongDate(selectedDate))}</h3>` +
          `</div>` +
        `</div>` +
        `<p class="inspector-text">Ein Tag kann mehrere Einträge enthalten. Wähle einen vorhandenen Eintrag zum Bearbeiten oder starte hier einen neuen Bereich.</p>` +
        `${content}` +
      `</div>`;
    bindInspectorEvents();
  }

  function renderDraftInspector() {
    const inspector = document.getElementById('calendar-inspector');
    if (!inspector || !state.createDraft) return;
    const draft = state.createDraft;
    inspector.innerHTML =
      `<div class="inspector-card is-draft-card">` +
        `<div class="inspector-head">` +
          `<div>` +
            `<p class="inspector-kicker">Neuer Eintrag</p>` +
            `<h3>Direkt im Kalender anlegen</h3>` +
          `</div>` +
          `<button type="button" class="admin-btn subtle small" data-action="cancel-create">Abbrechen</button>` +
        `</div>` +
        `<p class="inspector-text">Klicke im Kalender zuerst auf den Starttag und optional auf einen zweiten Tag für das Ende. Das eignet sich auch für lange Schließzeiten.</p>` +
        `<label class="inspector-field">` +
          `<span>Bezeichnung</span>` +
          `<input type="text" data-draft-field="label" value="${escapeHtml(draft.label)}" placeholder="z. B. Sommerschließzeit" />` +
        `</label>` +
        `<label class="inspector-field">` +
          `<span>Typ</span>` +
          `${renderTypeChips(draft.type || 'parent', 'draft')}` +
        `</label>` +
        `<div class="inspector-field-grid">` +
          `<label class="inspector-field">` +
            `<span>Start</span>` +
            `<input type="date" data-draft-field="start" value="${escapeHtml(draft.start || '')}" />` +
          `</label>` +
          `<label class="inspector-field">` +
            `<span>Ende</span>` +
            `<input type="date" data-draft-field="end" value="${escapeHtml(draft.end || '')}" />` +
          `</label>` +
        `</div>` +
        `<p class="draft-range-hint">${escapeHtml(formatDateRange(draft.start || '', draft.end || ''))}</p>` +
        `<div class="inspector-actions">` +
          `<button type="button" class="admin-btn subtle small" data-action="clear-draft-range">Kalenderauswahl leeren</button>` +
          `<button type="button" class="admin-btn" data-action="save-create">Eintrag übernehmen</button>` +
        `</div>` +
      `</div>`;
    bindInspectorEvents();
  }

  function renderEntryInspector() {
    const inspector = document.getElementById('calendar-inspector');
    const entry = getEntryById(state.selectedEntryId);
    if (!inspector || !entry) {
      state.selectedEntryId = '';
      renderDayInspector();
      return;
    }

    const meta = TYPE_META[entry.type] || TYPE_META.parent;
    inspector.innerHTML =
      `<div class="inspector-card ${meta.className}">` +
        `<div class="inspector-head">` +
          `<div>` +
            `<p class="inspector-kicker">Eintrag bearbeiten</p>` +
            `<h3>${escapeHtml(entry.label || 'Ohne Titel')}</h3>` +
          `</div>` +
          `<button type="button" class="admin-btn subtle small" data-action="clear-selection">Zur Tagesansicht</button>` +
        `</div>` +
        `<label class="inspector-field">` +
          `<span>Bezeichnung</span>` +
          `<input type="text" data-entry-id="${escapeHtml(entry.id)}" data-entry-field="label" value="${escapeHtml(entry.label)}" />` +
        `</label>` +
        `<label class="inspector-field">` +
          `<span>Typ</span>` +
          `${renderTypeChips(entry.type || 'parent', 'entry', entry.id)}` +
        `</label>` +
        `<div class="inspector-field-grid">` +
          `<label class="inspector-field">` +
            `<span>Start</span>` +
            `<input type="date" data-entry-id="${escapeHtml(entry.id)}" data-entry-field="start" value="${escapeHtml(entry.start || '')}" />` +
          `</label>` +
          `<label class="inspector-field">` +
            `<span>Ende</span>` +
            `<input type="date" data-entry-id="${escapeHtml(entry.id)}" data-entry-field="end" value="${escapeHtml(entry.end || '')}" />` +
          `</label>` +
        `</div>` +
        `<p class="draft-range-hint">${escapeHtml(formatDateRange(entry.start || '', entry.end || ''))}</p>` +
        `<div class="inspector-actions">` +
          `<button type="button" class="admin-btn danger small" data-action="remove-entry" data-entry-id="${escapeHtml(entry.id)}">Entfernen</button>` +
        `</div>` +
      `</div>`;
    bindInspectorEvents();
  }

  function renderInspector() {
    if (state.createDraft) {
      renderDraftInspector();
      return;
    }

    if (state.selectedEntryId) {
      renderEntryInspector();
      return;
    }

    renderDayInspector();
  }

  function handleDayClick(ymd) {
    if (!ymd) return;
    state.selectedDate = ymd;

    if (state.createDraft) {
      if (!state.createDraft.start || state.draftStep === 'pick_start') {
        state.createDraft.start = ymd;
        state.createDraft.end = '';
        state.draftStep = 'pick_end';
      } else {
        if (compareYmd(ymd, state.createDraft.start) < 0) {
          state.createDraft.end = state.createDraft.start;
          state.createDraft.start = ymd;
        } else if (ymd === state.createDraft.start) {
          state.createDraft.end = '';
        } else {
          state.createDraft.end = ymd;
        }
        state.draftStep = 'pick_start';
      }
    } else {
      state.selectedEntryId = '';
    }

    renderEvents();
  }

  function renderEvents() {
    const modeNote = document.getElementById('calendar-mode-note');
    syncTypeFilterButtons();

    const visibleEntries = getVisibleEntries();
    ensureUiState(visibleEntries);
    setFilterHint(visibleEntries.length);
    if (modeNote) {
      modeNote.hidden = !state.createDraft;
    }

    renderCalendar();
    renderInspector();
  }

  async function loadCollections() {
    const result = await api('/api/admin/collections');
    const draftEvents = Array.isArray(result?.draftData?.events) ? result.draftData.events : [];
    const publishedEvents = Array.isArray(result?.publishedData?.events) ? result.publishedData.events : [];
    const baselineEvents = Array.isArray(result?.baselineData?.events) ? result.baselineData.events : [];

    state.publishedEvents = sortEvents(publishedEvents.map((item) => ({ ...item })));
    state.baselineEvents = sortEvents(baselineEvents.map((item) => ({ ...item })));

    const shouldPreferBaseline = draftEvents.length <= 1 && publishedEvents.length <= 1 && baselineEvents.length > 1;
    state.events = sortEvents((shouldPreferBaseline ? baselineEvents : draftEvents).map((item) => ({ ...item })));
    state.source = shouldPreferBaseline ? 'baseline' : 'draft';
    state.viewYear = new Date().getFullYear();
    state.viewMonth = new Date().getMonth();
    state.selectedDate = todayYmd();
    setSourceHint();
    renderEvents();
  }

  async function saveEvents() {
    state.events = sortEvents(state.events);
    await api('/api/admin/collections', {
      method: 'PUT',
      headers: {
        'Content-Type': 'application/json',
        'x-cms-csrf': csrfToken,
      },
      body: JSON.stringify({ events: state.events }),
    });
  }

  document.getElementById('add-event-btn')?.addEventListener('click', () => {
    const prefillDate = state.selectedDate || todayYmd();
    state.createDraft = buildDraft(prefillDate);
    state.draftStep = prefillDate ? 'pick_end' : 'pick_start';
    state.selectedEntryId = '';
    renderEvents();
  });

  document.querySelectorAll('[data-type-filter]').forEach((button) => {
    button.addEventListener('click', () => {
      state.filterType = button.dataset.typeFilter || 'all';
      renderEvents();
    });
  });

  document.getElementById('clear-filters-btn')?.addEventListener('click', () => {
    state.filterType = 'all';
    state.viewYear = new Date().getFullYear();
    state.viewMonth = new Date().getMonth();
    renderEvents();
  });

  document.getElementById('calendar-prev-btn')?.addEventListener('click', () => {
    const next = addMonths(state.viewYear, state.viewMonth, -MONTHS_PER_PAGE);
    state.viewYear = next.year;
    state.viewMonth = next.month;
    renderEvents();
  });

  document.getElementById('calendar-next-btn')?.addEventListener('click', () => {
    const next = addMonths(state.viewYear, state.viewMonth, MONTHS_PER_PAGE);
    state.viewYear = next.year;
    state.viewMonth = next.month;
    renderEvents();
  });

  document.getElementById('calendar-today-btn')?.addEventListener('click', () => {
    const now = new Date();
    state.viewYear = now.getFullYear();
    state.viewMonth = now.getMonth();
    state.selectedDate = todayYmd();
    renderEvents();
  });

  document.getElementById('load-live-btn')?.addEventListener('click', () => {
    if (state.publishedEvents.length === 0) {
      setStatus('Keine Live-Einträge gefunden.');
      return;
    }
    if (!window.confirm('Entwurf mit Live-Daten ersetzen? Nicht gespeicherte Änderungen gehen verloren.')) return;
    state.events = sortEvents(state.publishedEvents.map((item) => ({ ...item })));
    state.source = 'published';
    setSourceHint();
    renderEvents();
    setStatus('Live-Daten geladen. Jetzt speichern, wenn du sie behalten willst.');
  });

  document.getElementById('load-baseline-btn')?.addEventListener('click', () => {
    if (state.baselineEvents.length === 0) {
      setStatus('Keine Website-Standarddaten gefunden.');
      return;
    }
    if (!window.confirm('Entwurf mit Website-Standard ersetzen? Nicht gespeicherte Änderungen gehen verloren.')) return;
    state.events = sortEvents(state.baselineEvents.map((item) => ({ ...item })));
    state.source = 'baseline';
    setSourceHint();
    renderEvents();
    setStatus('Website-Standard geladen. Jetzt speichern, wenn du ihn behalten willst.');
  });

  document.getElementById('save-events-btn')?.addEventListener('click', async () => {
    try {
      setStatus('Speichere Entwurf ...');
      await saveEvents();
      setStatus('Entwurf gespeichert.');
      renderEvents();
    } catch (error) {
      setStatus(error.message, true);
    }
  });

  document.getElementById('publish-btn')?.addEventListener('click', async () => {
    try {
      setStatus('Publiziere Entwurf ...');
      await api('/api/admin/publish', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'x-cms-csrf': csrfToken },
      });
      setStatus('Erfolgreich publiziert.');
    } catch (error) {
      setStatus(error.message, true);
    }
  });

  loadCollections().catch((error) => setStatus(error.message, true));
</script>


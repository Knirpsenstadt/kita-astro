---
import BaseLayout from '../layouts/BaseLayout.astro';
import eventsListScript from '../scripts/events-list.js?raw';
import { getBaselineEvents } from '../lib/cms/events';
import { getCmsRuntime } from '../lib/cms/runtime';

const cms = await getCmsRuntime(Astro);
const eventsData = cms.events(getBaselineEvents());
---

<BaseLayout title={cms.text('calendar.pageTitle', 'Kalender')} cms={cms}>
  <article class="prose max-w-none bg-white rounded-2xl shadow-sm border border-gray-100 p-6 lg:p-8">
    <div class="page-title-row">
      <div class="page-title-icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/></svg>
      </div>
      <h1 class="text-2xl font-bold !mt-0 !mb-0" {...cms.attrs('calendar.pageTitle')}>{cms.text('calendar.pageTitle', 'Kalender')}</h1>
    </div>

    <div class="highlight-box" style="margin-top: 1.5rem;">
      <span {...cms.attrs('calendar.pageIntro')}>{cms.text('calendar.pageIntro', 'Elterntermine, Familienveranstaltungen, Kinderaktionen und Schließzeiten im Überblick')}</span>
    </div>
    
    <div id="events-list" data-events-list style="margin-top: 1.5rem;">
      <script type="application/json" data-events set:html={JSON.stringify({ events: eventsData })}></script>
    </div>
  </article>
</BaseLayout>

<script define:vars={{ eventsListScript }}>
  const script = document.createElement('script');
  script.textContent = eventsListScript;
  document.head.appendChild(script);
</script>

<style is:global>
  #events-list {
    background: var(--brand-50);
    border: 1px solid var(--brand-100);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
  }
  
  .events-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  
  .events-filter {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  
  .filter-btn {
    padding: 0.5rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: #fff;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--ink-600);
    transition: all 0.2s;
  }
  
  .filter-btn:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }
  
  .filter-btn.active {
    box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.12);
  }

  .filter-btn[data-filter="all"] {
    background: #fff;
    border-color: var(--border);
    color: var(--ink-700);
  }

  .filter-btn.active[data-filter="all"] {
    background: var(--brand-600);
    border-color: var(--brand-600);
    color: #fff;
  }

  .filter-btn[data-filter="parent"] {
    background: #dbeafe;
    border-color: #93c5fd;
    color: #1d4ed8;
  }

  .filter-btn.active[data-filter="parent"] {
    background: #bfdbfe;
    border-color: #60a5fa;
    color: #1e3a8a;
  }

  .filter-btn[data-filter="family"] {
    background: #dcfce7;
    border-color: #86efac;
    color: #166534;
  }

  .filter-btn.active[data-filter="family"] {
    background: #bbf7d0;
    border-color: #4ade80;
    color: #14532d;
  }

  .filter-btn[data-filter="child"] {
    background: #ffedd5;
    border-color: #fdba74;
    color: #c2410c;
  }

  .filter-btn.active[data-filter="child"] {
    background: #fed7aa;
    border-color: #fb923c;
    color: #9a3412;
  }

  .filter-btn[data-filter="closure"] {
    background: #fee2e2;
    border-color: #fca5a5;
    color: #b91c1c;
  }

  .filter-btn.active[data-filter="closure"] {
    background: #fecaca;
    border-color: #f87171;
    color: #991b1b;
  }
  
  .events-list {
    display: grid;
    gap: 0.75rem;
  }

  .events-section + .events-section {
    margin-top: 1.5rem;
  }

  .event-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: #fff;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .event-item.is-past {
    background: #f9fafb;
    border-color: #d1d5db;
  }
  
  .event-item:hover {
    transform: translateX(4px);
    box-shadow: var(--shadow-sm);
  }

  .event-item.is-past:hover {
    transform: translateX(4px);
  }
  
  .event-date {
    min-width: 70px;
    text-align: center;
    padding: 0.75rem;
    background: var(--brand-50);
    border: 1px solid var(--brand-100);
    border-radius: var(--radius-sm);
  }
  
  .event-date .day {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--brand-800);
    line-height: 1;
  }
  
  .event-date .month {
    font-size: 0.8rem;
    color: var(--brand-700);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.025em;
  }
  
  .event-content {
    flex: 1;
    min-width: 0;
  }
  
  .event-title {
    font-weight: 700;
    color: var(--ink-700);
    margin-bottom: 0.15rem;
  }
  
  .event-duration {
    font-size: 0.85rem;
    color: var(--muted);
  }
  
  .event-type {
    flex-shrink: 0;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.025em;
  }

  .event-title,
  .event-duration {
    overflow-wrap: anywhere;
  }

  .event-item.is-past .event-date {
    background: #f3f4f6;
    border-color: #d1d5db;
  }

  .event-item.is-past .event-date .day {
    color: #374151;
  }

  .event-item.is-past .event-date .month,
  .event-item.is-past .event-title,
  .event-item.is-past .event-duration {
    color: #6b7280;
  }

  .event-item.is-past .event-type {
    filter: grayscale(1);
    border-color: #d1d5db;
  }
  
  .event-type.closure {
    background: #fecaca;
    color: #991b1b;
  }
  
  .event-type.family {
    background: #bbf7d0;
    color: #166534;
  }
  
  .event-type.child {
    background: #fed7aa;
    color: #9a3412;
  }

  .event-type.parent {
    background: #bfdbfe;
    color: #1e40af;
  }
  
  .no-events {
    text-align: center;
    padding: 3rem 2rem;
    color: var(--muted);
  }
  
  .no-events svg {
    width: 48px;
    height: 48px;
    margin-bottom: 1rem;
    opacity: 0.4;
  }

  @media (max-width: 640px) {
    #events-list {
      padding: 1rem;
    }

    .event-item {
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .event-date {
      min-width: 64px;
      padding: 0.65rem;
    }

    .event-content {
      flex-basis: calc(100% - 80px);
    }

    .event-type {
      margin-left: 80px;
    }
  }

  @media (max-width: 420px) {
    .event-item {
      gap: 0.85rem;
    }

    .event-content,
    .event-type {
      flex-basis: 100%;
      margin-left: 0;
    }

    .event-type {
      justify-self: flex-start;
    }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import ContentBlocks from '../components/ContentBlocks.astro';
import { getIconPath } from '../lib/iconOptions';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map(page => ({
    params: { slug: page.data.permalink?.replace(/^\//, '').replace(/\/$/, '') || page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { title } = page.data;
const slug = page.data.permalink?.replace(/^\//, '').replace(/\/$/, '') || page.id;
const { Content } = await render(page);
const hasBody = page.body?.trim().length > 0;

// Icon mapping for each page
const pageIcons: Record<string, string> = {
  'paedagogischer-ansatz': 'book-open',
  'team': 'users',
  'vereinsleben': 'users',
  'dokumente': 'document',
  'stellen': 'briefcase',
  'impressum': 'info',
};

const iconPath = getIconPath(pageIcons[slug], 'book-open');
---

<BaseLayout title={title}>
  <article class="prose max-w-none bg-white rounded-2xl shadow-sm border border-gray-100 p-6 lg:p-8">
    <div class="page-title-row">
      <div class="page-title-icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d={iconPath}></path>
        </svg>
      </div>
      <h1 class="text-2xl font-bold !mt-0 !mb-0">{title}</h1>
    </div>
    {hasBody ? <Content /> : <ContentBlocks blocks={page.data.blocks} />}
  </article>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import ContentBlocks from '../components/ContentBlocks.astro';
import { getIconPath } from '../lib/iconOptions';
import { getCmsRuntime } from '../lib/cms/runtime';

const slug = Astro.params.slug || '';
const pages = await getCollection('pages');
const page = pages.find((entry) => {
  const entrySlug = entry.data.permalink?.replace(/^\//, '').replace(/\/$/, '') || entry.id.replace('/index', '');
  return entrySlug === slug;
});

const cms = await getCmsRuntime(Astro);

if (!page) {
  Astro.response.status = 404;
}

const pageTitle = page?.data.title || 'Seite nicht gefunden';
const title = cms.text(`pages.${slug}.title`, pageTitle);
const titleAttrs = slug === 'dokumente' ? {} : cms.attrs(`pages.${slug}.title`);
const rendered = page ? await render(page) : null;
const Content = rendered?.Content;
const hasBody = (page?.body?.trim().length ?? 0) > 0;

// Icon mapping for each page
const pageIcons: Record<string, string> = {
  'paedagogischer-ansatz': 'book-open',
  'team': 'users',
  'vereinsleben': 'users',
  'dokumente': 'document',
  'stellen': 'briefcase',
  'impressum': 'info',
  'datenschutz': 'shield',
};

const iconPath = getIconPath(pageIcons[slug], 'book-open');
---

<BaseLayout title={title} cms={cms}>
  {page ? (
    <article class="prose max-w-none bg-white rounded-2xl shadow-sm border border-gray-100 p-6 lg:p-8">
      <div class="page-title-row">
        <div class="page-title-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d={iconPath}></path>
          </svg>
        </div>
        <h1 class="text-2xl font-bold !mt-0 !mb-0" {...titleAttrs}>{title}</h1>
      </div>
      {hasBody && Content ? <Content /> : <ContentBlocks blocks={page.data.blocks} cms={cms} contentKeyPrefix={`pages.${slug}.blocks`} />}
    </article>
  ) : (
    <article class="prose max-w-none bg-white rounded-2xl shadow-sm border border-gray-100 p-6 lg:p-8">
      <h1>Seite nicht gefunden</h1>
      <p>Der gewuenschte Inhalt ist nicht verfuegbar.</p>
    </article>
  )}
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import ContentBlocks from '../components/ContentBlocks.astro';
import { getIconPath } from '../lib/iconOptions';

const pages = await getCollection('pages');
const impressumPage = pages.find(p => p.id === 'impressum/index' || p.id === 'impressum');
const { Content } = impressumPage ? await render(impressumPage) : { Content: null };
const hasBody = impressumPage?.body?.trim().length ? true : false;
---

<BaseLayout title="Kontakt & Impressum">
  {impressumPage ? (
    <article class="prose max-w-none bg-white rounded-2xl shadow-sm border border-gray-100 p-6 lg:p-8">
      <div class="page-title-row">
        <div class="page-title-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d={getIconPath('info')} />
          </svg>
        </div>
        <h1 class="text-2xl font-bold !mt-0 !mb-0">Kontakt & Impressum</h1>
      </div>
      {hasBody && Content ? <Content /> : <ContentBlocks blocks={impressumPage.data.blocks} />}
    </article>
  ) : (
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 lg:p-8">
      <h1>Impressum</h1>
      <p>Impressum nicht gefunden.</p>
    </div>
  )}
</BaseLayout>

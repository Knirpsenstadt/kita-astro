---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const pages = await getCollection('pages');
const impressumPage = pages.find(p => p.id === 'impressum');
const { Content } = impressumPage ? await render(impressumPage) : { Content: null };
---

<BaseLayout title="Kontakt & Impressum">
  {Content ? (
    <article class="prose max-w-none bg-white rounded-xl shadow-sm border border-gray-100 p-6 lg:p-8">
      <Content />
    </article>
  ) : (
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 lg:p-8">
      <h1>Impressum</h1>
      <p>Impressum nicht gefunden.</p>
    </div>
  )}
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Impressum">
  <h1 class="text-2xl font-bold mb-6">Impressum</h1>
  
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <h2 class="text-lg font-semibold mb-4">Angaben gemäß § 5 TMG</h2>
    
    <p class="mb-4">
      Elternverein Knirpsenstadt e.V.<br />
      [Adresse ergänzen]<br />
      [PLZ Ort]
    </p>
    
    <h3 class="font-semibold mt-6 mb-2">Vertreten durch:</h3>
    <p class="mb-4">[Vorstandsmitglieder]</p>
    
    <h3 class="font-semibold mt-6 mb-2">Kontakt:</h3>
    <p class="mb-4">
      Telefon: [Telefonnummer]<br />
      E-Mail: leitung@knirpsenstadt.de
    </p>
    
    <h3 class="font-semibold mt-6 mb-2">Registereintrag:</h3>
    <p class="mb-4">
      Eintragung im Vereinsregister<br />
      Registergericht: [Gericht]<br />
      Registernummer: [Nummer]
    </p>
  </div>
</BaseLayout>
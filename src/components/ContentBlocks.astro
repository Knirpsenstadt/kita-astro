---
import { getIconPath } from '../lib/iconOptions'
import type { CmsRuntime } from '../lib/cms/runtime'

interface Props {
  blocks?: any[]
  cms?: CmsRuntime
  contentKeyPrefix?: string
}

const { blocks = [], cms, contentKeyPrefix = 'page.blocks' } = Astro.props

const text = (key: string, fallback: string) => (cms ? cms.text(key, fallback) : fallback)
const attrs = (key: string) => (cms ? cms.attrs(key) : {})
---

{blocks.map((block: any, blockIndex: number) => {
  const blockKey = `${contentKeyPrefix}.${blockIndex}`

  if (block._template === 'heading') {
    const Tag = block.level === 'h3' ? 'h3' : 'h2'
    return <Tag {...attrs(`${blockKey}.headingText`)}>{text(`${blockKey}.headingText`, block.headingText || '')}</Tag>
  }

  if (block._template === 'paragraph') {
    return <p {...attrs(`${blockKey}.bodyText`)}>{text(`${blockKey}.bodyText`, block.bodyText || '')}</p>
  }

  if (block._template === 'highlightBox') {
    return (
      <div class="highlight-box">
        <p {...attrs(`${blockKey}.highlightText`)}>{text(`${blockKey}.highlightText`, block.highlightText || '')}</p>
      </div>
    )
  }

  if (block._template === 'featureGrid') {
    return (
      <div class="feature-grid">
        {block.cards?.map((item: any, cardIndex: number) => {
          const cardKey = `${blockKey}.cards.${cardIndex}`
          const iconPath = getIconPath(item.icon)
          if (item.href) {
            return (
              <a href={item.href} class="feature-card" style="text-decoration:none;" target={item.href.startsWith('http') ? '_blank' : undefined}>
                <div class="feature-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d={iconPath}></path>
                  </svg>
                </div>
                <div class="feature-content">
                  <h3 {...attrs(`${cardKey}.title`)}>{text(`${cardKey}.title`, item.title || '')}</h3>
                  <p {...attrs(`${cardKey}.description`)}>{text(`${cardKey}.description`, item.description || '')}</p>
                </div>
              </a>
            )
          }

          return (
            <div class="feature-card">
              <div class="feature-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d={iconPath}></path>
                </svg>
              </div>
              <div class="feature-content">
                <h3 {...attrs(`${cardKey}.title`)}>{text(`${cardKey}.title`, item.title || '')}</h3>
                <p {...attrs(`${cardKey}.description`)}>{text(`${cardKey}.description`, item.description || '')}</p>
              </div>
            </div>
          )
        })}
      </div>
    )
  }

  if (block._template === 'educationGrid') {
    return (
      <div class="edu-grid">
        {block.areas?.map((item: any, areaIndex: number) => (
          <div class="edu-item">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d={getIconPath(item.icon, 'lightbulb')}></path>
            </svg>
            <span {...attrs(`${blockKey}.areas.${areaIndex}.label`)}>{text(`${blockKey}.areas.${areaIndex}.label`, item.label || '')}</span>
          </div>
        ))}
      </div>
    )
  }

  if (block._template === 'iconList') {
    return (
      <ul class="icon-list">
        {block.entries?.map((item: any, entryIndex: number) => (
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d={getIconPath(item.icon, 'sparkles')}></path>
            </svg>
            <span {...attrs(`${blockKey}.entries.${entryIndex}.entryText`)}>{text(`${blockKey}.entries.${entryIndex}.entryText`, item.entryText || '')}</span>
          </li>
        ))}
      </ul>
    )
  }

  if (block._template === 'twoColumns') {
    return (
      <div class="two-columns">
        {block.columns?.map((column: any, columnIndex: number) => (
          <div class="column-card">
            <h3 {...attrs(`${blockKey}.columns.${columnIndex}.title`)}>{text(`${blockKey}.columns.${columnIndex}.title`, column.title || '')}</h3>
            <ul>
              {column.bulletItems?.map((listItem: string, itemIndex: number) => (
                <li {...attrs(`${blockKey}.columns.${columnIndex}.bulletItems.${itemIndex}`)}>{text(`${blockKey}.columns.${columnIndex}.bulletItems.${itemIndex}`, listItem || '')}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    )
  }

  if (block._template === 'infoBox') {
    return (
      <div class="info-box">
        <h3>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d={getIconPath(block.icon, 'info')}></path>
          </svg>
          <span {...attrs(`${blockKey}.title`)}>{text(`${blockKey}.title`, block.title || '')}</span>
        </h3>
        {block.infoText && <p {...attrs(`${blockKey}.infoText`)}>{text(`${blockKey}.infoText`, block.infoText || '')}</p>}
        {block.bulletItems && block.bulletItems.length > 0 && (
          <ul>
            {block.bulletItems.map((item: string, itemIndex: number) => (
              <li {...attrs(`${blockKey}.bulletItems.${itemIndex}`)}>{text(`${blockKey}.bulletItems.${itemIndex}`, item || '')}</li>
            ))}
          </ul>
        )}
      </div>
    )
  }

  if (block._template === 'docGrid') {
    return (
      <div class="doc-grid">
        {block.documents?.map((item: any, documentIndex: number) => (
          <a href={item.href} class="doc-card" target="_blank" rel="noopener noreferrer">
            <div class="doc-icon">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={getIconPath(item.icon, 'document')}></path>
              </svg>
            </div>
            <div class="doc-content">
              <h3 {...attrs(`${blockKey}.documents.${documentIndex}.title`)}>{text(`${blockKey}.documents.${documentIndex}.title`, item.title || '')}</h3>
              {item.description && <p {...attrs(`${blockKey}.documents.${documentIndex}.description`)}>{text(`${blockKey}.documents.${documentIndex}.description`, item.description || '')}</p>}
              <span class="doc-badge" {...attrs(`${blockKey}.documents.${documentIndex}.badge`)}>{text(`${blockKey}.documents.${documentIndex}.badge`, item.badge || 'PDF')}</span>
            </div>
          </a>
        ))}
      </div>
    )
  }

  if (block._template === 'badge') {
    return <span class="badge-green" {...attrs(`${blockKey}.badgeText`)}>{text(`${blockKey}.badgeText`, block.badgeText || '')}</span>
  }

  if (block._template === 'separator') {
    return <hr class="content-separator" />
  }

  if (block._template === 'centerNotice') {
    return (
      <div class="center-notice">
        <div class="center-notice-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d={getIconPath(block.icon, 'info')}></path>
          </svg>
        </div>
        <p class="center-notice-headline" {...attrs(`${blockKey}.headline`)}>{text(`${blockKey}.headline`, block.headline || '')}</p>
        {block.subline && <p class="center-notice-subline" {...attrs(`${blockKey}.subline`)}>{text(`${blockKey}.subline`, block.subline || '')}</p>}
      </div>
    )
  }

  return null
})}
